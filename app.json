{
  "expo": {
    "name": "FitTrack",
    "slug": "fittrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#16181a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fittrack.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#8fa68e"
      },
      "package": "com.fittrack.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-font"
    ],
    "scheme": "fittrack",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "2849ac83-272e-4e27-8411-3505b3bcb5d1"
      }
    },
    "owner": "robinmanuel",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2849ac83-272e-4e27-8411-3505b3bcb5d1"
    }
  }
}
